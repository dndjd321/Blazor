@page "/finance"
@rendermode InteractiveServer
@using System.Net.Http
@using System.Text.Json
@using System.Linq

<PageTitle>AI 통계 기반 미래 예측기</PageTitle>

<div class="container-fluid py-4" style="max-width: 1200px;">
    
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #2c3e50;">
            <i class="bi bi-bar-chart-line-fill text-primary me-2"></i>글로벌 자산 1만 번 시뮬레이터
        </h2>
        <p class="text-muted fs-5">주요 종목은 간편하게 선택하고, 없는 종목은 검색해서 6개월 뒤 미래를 시뮬레이션하세요.</p>
    </div>

    <div class="alert alert-light shadow-sm border d-flex align-items-center mb-4">
        <i class="bi bi-currency-exchange fs-3 text-success me-3"></i>
        <div>
            <h6 class="mb-0 text-muted">실시간 시장 데이터</h6>
            @if (IsLoadingRate)
            {
                <span class="spinner-border spinner-border-sm text-primary mt-1"></span> <span class="text-muted ms-1">환율 정보를 불러오는 중입니다...</span>
            }
            else
            {
                <div class="fs-5 mt-1">현재 원/달러 환율: <strong class="text-primary">@CurrentExchangeRate.ToString("N2") 원</strong></div>
            }
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0" style="background-color: #f0f8ff;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color: #0056b3;"><i class="bi bi-pie-chart-fill me-2"></i>1. 시장 지수 (프리셋)</h5>
                    <div class="input-group shadow-sm">
                        <select class="form-select border-0" @bind="SelectedPreset">
                            <option value="">-- 지수 선택 --</option>
                            <option value="kospi">🇰🇷 코스피 지수</option>
                            <option value="snp500">🇺🇸 S&P 500</option>
                            <option value="nasdaq">🇺🇸 나스닥 100</option>
                        </select>
                        <button class="btn btn-primary fw-bold px-3" @onclick="ApplyPreset">적용</button>
                    </div>
                    <small class="text-muted mt-2 d-block"><i class="bi bi-info-circle me-1"></i>빠른 통계 기반 세팅입니다.</small>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card h-100 shadow-sm border-0" style="background-color: #fffdf5;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color: #856404;"><i class="bi bi-search me-2"></i>2. 개별 종목 (6개월 실데이터 연동)</h5>
                    
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label text-muted fw-bold" style="font-size: 0.85rem;">🇰🇷 국내 주식 Top 5</label>
                            <select class="form-select form-select-sm shadow-sm border-0" value="@SelectedDomestic" @onchange='(e) => OnAssetSelected(e, "domestic")'>
                                <option value="">-- 선택 --</option>
                                <option value="005930.KS">삼성전자</option>
                                <option value="000660.KS">SK하이닉스</option>
                                <option value="005380.KS">현대차</option>
                                <option value="035420.KS">NAVER</option>
                                <option value="035720.KS">카카오</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted fw-bold" style="font-size: 0.85rem;">🇺🇸 해외 주식 Top 5</label>
                            <select class="form-select form-select-sm shadow-sm border-0" value="@SelectedOverseas" @onchange='(e) => OnAssetSelected(e, "overseas")'>
                                <option value="">-- 선택 --</option>
                                <option value="AAPL">애플</option>
                                <option value="NVDA">엔비디아</option>
                                <option value="TSLA">테슬라</option>
                                <option value="MSFT">마이크로소프트</option>
                                <option value="GOOGL">알파벳(구글)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted fw-bold" style="font-size: 0.85rem;">🪙 암호화폐 Top 5</label>
                            <select class="form-select form-select-sm shadow-sm border-0" value="@SelectedCrypto" @onchange='(e) => OnAssetSelected(e, "crypto")'>
                                <option value="">-- 선택 --</option>
                                <option value="BTC-USD">비트코인</option>
                                <option value="ETH-USD">이더리움</option>
                                <option value="SOL-USD">솔라나</option>
                                <option value="XRP-USD">리플</option>
                                <option value="DOGE-USD">도지코인</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-2">
                        <hr class="flex-grow-1" style="border-color: #e2d1a4;" />
                        <span class="mx-3 text-muted fw-bold" style="font-size: 0.85rem;">OR</span>
                        <hr class="flex-grow-1" style="border-color: #e2d1a4;" />
                    </div>

                    <div class="input-group shadow-sm mb-2">
                        <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control form-control-sm border-0" placeholder="종목명/티커 검색 (예: TSLA, 카카오뱅크)" 
                               @bind="SearchQuery" @onkeyup="HandleKeyUp" />
                        <button class="btn btn-warning btn-sm fw-bold px-3" type="button" @onclick="SearchAssetsApi" disabled="@IsSearching">
                            @if (IsSearching) { <span class="spinner-border spinner-border-sm"></span> } else { <span>검색</span> }
                        </button>
                    </div>

                    @if (SearchResults.Any())
                    {
                        <div class="list-group shadow-sm mt-2" style="max-height: 150px; overflow-y: auto;">
                            @foreach (var item in SearchResults)
                            {
                                <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2" 
                                        @onclick="() => FetchAndCalculateHistoricalData(item.Symbol, item.Name)">
                                    <span><strong class="text-dark">@item.Name</strong> <span class="text-muted ms-1" style="font-size: 0.85em;">(@item.Symbol)</span></span>
                                    <span class="badge bg-light text-dark border">@item.Exchange</span>
                                </button>
                            }
                        </div>
                    }
                    
                    <div style="min-height: 24px; margin-top: 10px;">
                        @if (IsFetchingHistory)
                        {
                            <div class="text-primary fw-bold" style="font-size: 0.9em;">
                                <span class="spinner-border spinner-border-sm me-1"></span> 실데이터 연동 중...
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(HistoryMessage))
                        {
                            <div class="fw-bold px-2 py-1 rounded" style="font-size: 0.9em; background-color: rgba(255,255,255,0.7); color: @(HistoryMessage.Contains("실패") || HistoryMessage.Contains("오류") ? "#dc3545" : "#198754");">
                                @if(HistoryMessage.Contains("실패") || HistoryMessage.Contains("오류")) { <i class="bi bi-x-circle me-1"></i> } else { <i class="bi bi-check-circle me-1"></i> }
                                @HistoryMessage
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-white">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-4"><i class="bi bi-pencil-square text-secondary me-2"></i>분석된 시나리오 수치 (자동 세팅됨)</h5>
            <div class="row g-4">
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted">초기 투자금 (원화)</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-light border-0">₩</span>
                        <input type="number" @bind="Capital" class="form-control border-0" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted">기대 수익률 (연 %)</label>
                    <div class="input-group shadow-sm">
                        <input type="number" @bind="ExpectedDrift" class="form-control border-0 text-end" />
                        <span class="input-group-text bg-light border-0">%</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted">변동성 / 위험도 (연 %)</label>
                    <div class="input-group shadow-sm">
                        <input type="number" @bind="Volatility" class="form-control border-0 text-end" />
                        <span class="input-group-text bg-light border-0">%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <button class="btn btn-primary btn-lg w-100 fw-bold shadow mb-5" style="padding: 15px; font-size: 1.2rem; border-radius: 10px;" @onclick="RunSimulation" disabled="@IsLoadingRate">
        <i class="bi bi-rocket-takeoff-fill me-2"></i>데이터 기반 10,000번 시뮬레이션 실행하기
    </button>

    @if (IsSimulated)
    {
        <div class="card shadow border-primary border-2" style="border-radius: 15px; overflow: hidden;">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-graph-up-arrow me-2"></i>6개월 뒤 예상 자산 분포도</h4>
            </div>
            <div class="card-body p-4 bg-white">
                
                <div class="mb-4">
                    <div style="display: flex; align-items: flex-end; height: 200px; border-bottom: 2px solid #ccc; gap: 2px;">
                        @foreach (var bucket in HistogramBuckets)
                        {
                            <div style="flex: 1; background-color: @(bucket.IsProfit ? "#28a745" : "#dc3545"); height: @(bucket.HeightPercentage)%; opacity: 0.8; border-radius: 2px 2px 0 0;" 
                                 title="예상자산: @bucket.Label.ToString("N0")원 (확률: @bucket.Probability.ToString("N1")%)">
                            </div>
                        }
                    </div>
                    <div class="d-flex justify-content-between mt-2 text-muted fw-bold" style="font-size: 0.85em;">
                        <span><i class="bi bi-arrow-left"></i> 비관적 (손실)</span>
                        <span>평균적인 미래</span>
                        <span>낙관적 (수익) <i class="bi bi-arrow-right"></i></span>
                    </div>
                </div>

                <table class="table table-hover text-center align-middle" style="font-size: 1.1em;">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3 text-muted">시나리오</th>
                            <th class="py-3 text-muted">6개월 뒤 예상 자산</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="text-success fw-bold py-3"><i class="bi bi-emoji-sunglasses text-success me-2"></i>상위 10% (낙관적)</td>
                            <td class="text-success fw-bold py-3">@Top10Result.ToString("N0") 원</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-dark py-3"><i class="bi bi-emoji-neutral text-secondary me-2"></i>중앙값 (현실적)</td>
                            <td class="fw-bold text-dark py-3">@MedianResult.ToString("N0") 원</td>
                        </tr>
                        <tr>
                            <td class="text-danger fw-bold py-3"><i class="bi bi-emoji-frown text-danger me-2"></i>하위 10% (비관적)</td>
                            <td class="text-danger fw-bold py-3">@Bottom10Result.ToString("N0") 원</td>
                        </tr>
                    </tbody>
                </table>
                
                <div class="text-center mt-4 p-4 rounded bg-light border">
                    <h4 class="mb-0 text-dark">
                        원금 방어 확률: 
                        <strong class="text-primary fs-2 ms-2">@WinRate.ToString("N1")%</strong>
                    </h4>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // ⬇️ 아래 C# 코드는 기존과 100% 동일하게 유지됩니다. 
    private double CurrentExchangeRate = 1350;
    private bool IsLoadingRate = true;
    
    private string SelectedPreset = "";

    private string SelectedDomestic = "";
    private string SelectedOverseas = "";
    private string SelectedCrypto = "";

    private string SearchQuery = "";
    private bool IsSearching = false;
    private List<AssetResult> SearchResults = new();
    
    private bool IsFetchingHistory = false;
    private string HistoryMessage = "";

    private double Capital = 10000000;
    private double ExpectedDrift = 5.0; 
    private double Volatility = 15.0;   

    private double MedianResult;
    private double Top10Result;
    private double Bottom10Result;
    private double WinRate;
    private bool IsSimulated = false;

    private readonly Dictionary<string, string> TickerNames = new()
    {
        {"005930.KS", "삼성전자"}, {"000660.KS", "SK하이닉스"}, {"005380.KS", "현대차"}, {"035420.KS", "NAVER"}, {"035720.KS", "카카오"},
        {"AAPL", "애플"}, {"NVDA", "엔비디아"}, {"TSLA", "테슬라"}, {"MSFT", "마이크로소프트"}, {"GOOGL", "알파벳(구글)"},
        {"BTC-USD", "비트코인"}, {"ETH-USD", "이더리움"}, {"SOL-USD", "솔라나"}, {"XRP-USD", "리플"}, {"DOGE-USD", "도지코인"}
    };

    public class AssetResult
    {
        public string Symbol { get; set; }
        public string Name { get; set; }
        public string Exchange { get; set; }
    }

    public class Bucket
    {
        public double Label { get; set; }
        public double HeightPercentage { get; set; }
        public bool IsProfit { get; set; }
        public double Probability { get; set; }
    }
    private List<Bucket> HistogramBuckets = new List<Bucket>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var client = new HttpClient();
            var response = await client.GetStringAsync("https://open.er-api.com/v6/latest/USD");
            using var doc = JsonDocument.Parse(response);
            CurrentExchangeRate = doc.RootElement.GetProperty("rates").GetProperty("KRW").GetDouble();
        }
        catch { }
        finally { IsLoadingRate = false; }
    }

    private void ApplyPreset()
    {
        if (string.IsNullOrEmpty(SelectedPreset)) return;

        HistoryMessage = ""; 
        SearchResults.Clear(); 
        IsSimulated = false;

        switch (SelectedPreset)
        {
            case "kospi": ExpectedDrift = 5.0; Volatility = 18.0; HistoryMessage = "코스피 지수 세팅 완료 (통계 기반)"; break;
            case "snp500": ExpectedDrift = 10.0; Volatility = 15.0; HistoryMessage = "S&P 500 지수 세팅 완료 (통계 기반)"; break;
            case "nasdaq": ExpectedDrift = 15.0; Volatility = 25.0; HistoryMessage = "나스닥 지수 세팅 완료 (통계 기반)"; break;
        }

        SelectedDomestic = ""; SelectedOverseas = ""; SelectedCrypto = "";
    }

    private async Task OnAssetSelected(ChangeEventArgs e, string category)
    {
        string ticker = e.Value?.ToString() ?? "";

        if (category == "domestic") { SelectedOverseas = ""; SelectedCrypto = ""; }
        else if (category == "overseas") { SelectedDomestic = ""; SelectedCrypto = ""; }
        else if (category == "crypto") { SelectedDomestic = ""; SelectedOverseas = ""; }

        if (string.IsNullOrEmpty(ticker)) return;

        string displayName = TickerNames.ContainsKey(ticker) ? TickerNames[ticker] : ticker;
        await FetchAndCalculateHistoricalData(ticker, displayName);
        
        SelectedDomestic = ""; SelectedOverseas = ""; SelectedCrypto = "";
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAssetsApi();
    }

    private async Task SearchAssetsApi()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery)) return;
        IsSearching = true;
        SearchResults.Clear();
        HistoryMessage = "";

        try
        {
            using var client = new HttpClient();
            client.DefaultRequestHeaders.Add("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64)");
            string url = $"https://query1.finance.yahoo.com/v1/finance/search?q={Uri.EscapeDataString(SearchQuery)}&quotesCount=6";
            var response = await client.GetStringAsync(url);
            
            using var doc = JsonDocument.Parse(response);
            var quotes = doc.RootElement.GetProperty("quotes");

            foreach (var quote in quotes.EnumerateArray())
            {
                if (quote.TryGetProperty("symbol", out var symbolProp) && 
                    quote.TryGetProperty("shortname", out var nameProp))
                {
                    string exchange = quote.TryGetProperty("exchDisp", out var exchProp) ? exchProp.GetString() : "";
                    
                    SearchResults.Add(new AssetResult
                    {
                        Symbol = symbolProp.GetString(),
                        Name = nameProp.GetString(),
                        Exchange = exchange
                    });
                }
            }
            
            if (!SearchResults.Any()) HistoryMessage = "검색 결과가 없습니다. (영어 티커로 검색해 보세요. 예: AAPL)";
        }
        catch (Exception ex)
        {
            HistoryMessage = $"검색 중 오류가 발생했습니다. (영문/티커로 다시 시도해보세요)";
        }
        finally
        {
            IsSearching = false;
        }
    }

    private async Task FetchAndCalculateHistoricalData(string ticker, string displayName)
    {
        IsFetchingHistory = true;
        HistoryMessage = "";
        IsSimulated = false;
        SearchResults.Clear(); 

        try
        {
            using var client = new HttpClient();
            client.DefaultRequestHeaders.Add("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36");

            string url = $"https://query1.finance.yahoo.com/v8/finance/chart/{ticker}?range=6mo&interval=1d";
            var response = await client.GetStringAsync(url);
            using var doc = JsonDocument.Parse(response);
            var resultElement = doc.RootElement.GetProperty("chart").GetProperty("result")[0];
            var closePricesElement = resultElement.GetProperty("indicators").GetProperty("quote")[0].GetProperty("close");

            List<double> closes = new List<double>();
            foreach (var price in closePricesElement.EnumerateArray())
            {
                if (price.ValueKind == JsonValueKind.Number) closes.Add(price.GetDouble());
            }

            if (closes.Count > 1)
            {
                List<double> dailyReturns = new List<double>();
                for (int i = 1; i < closes.Count; i++)
                {
                    if (closes[i - 1] > 0 && closes[i] > 0)
                        dailyReturns.Add(Math.Log(closes[i] / closes[i - 1]));
                }

                double meanDailyReturn = dailyReturns.Average();
                double variance = dailyReturns.Select(r => Math.Pow(r - meanDailyReturn, 2)).Sum() / (dailyReturns.Count - 1);
                double stdDevDaily = Math.Sqrt(variance);
                int daysInYear = ticker.Contains("USD") || ticker.Contains("-") ? 365 : 252;

                ExpectedDrift = Math.Round((meanDailyReturn * daysInYear) * 100.0, 2);
                Volatility = Math.Round((stdDevDaily * Math.Sqrt(daysInYear)) * 100.0, 2);

                HistoryMessage = $"'{displayName}' 6개월 실데이터 연동 완료!";
            }
            else
            {
                HistoryMessage = $"'{displayName}'의 거래 데이터가 부족합니다.";
            }
        }
        catch
        {
            HistoryMessage = $"'{displayName}' 실데이터 연동 실패! (상장 폐지, 또는 일시적 API 차단)";
        }
        finally
        {
            IsFetchingHistory = false;
        }
    }

    private void RunSimulation()
    {
        int simulationCount = 10000;
        var rand = new Random();
        var results = new double[simulationCount];
        
        double dt = 6.0 / 12.0;
        double mu = ExpectedDrift / 100.0;
        double sigma = Volatility / 100.0;

        int winCount = 0;
        double minResult = double.MaxValue;
        double maxResult = double.MinValue;

        for (int i = 0; i < simulationCount; i++)
        {
            double u1 = 1.0 - rand.NextDouble();
            double u2 = 1.0 - rand.NextDouble();
            double z = Math.Sqrt(-2.0 * Math.Log(u1)) * Math.Cos(2.0 * Math.PI * u2);
            double finalValue = Capital * Math.Exp((mu - (sigma * sigma / 2.0)) * dt + sigma * Math.Sqrt(dt) * z);
            results[i] = finalValue;

            if (finalValue >= Capital) winCount++;
            if (finalValue < minResult) minResult = finalValue;
            if (finalValue > maxResult) maxResult = finalValue;
        }

        Array.Sort(results);
        MedianResult = results[simulationCount / 2];
        Top10Result = results[(int)(simulationCount * 0.90)];
        Bottom10Result = results[(int)(simulationCount * 0.10)];
        WinRate = (double)winCount / simulationCount * 100.0;

        int bucketCount = 50; 
        double bucketSize = (maxResult - minResult) / bucketCount;
        int[] counts = new int[bucketCount];
        int maxCount = 0;

        foreach (var res in results)
        {
            int index = (int)((res - minResult) / bucketSize);
            if (index >= bucketCount) index = bucketCount - 1;
            counts[index]++;
            if (counts[index] > maxCount) maxCount = counts[index];
        }

        HistogramBuckets.Clear();
        for (int i = 0; i < bucketCount; i++)
        {
            double bucketValue = minResult + (i * bucketSize);
            HistogramBuckets.Add(new Bucket
            {
                Label = bucketValue,
                HeightPercentage = ((double)counts[i] / maxCount) * 100.0,
                IsProfit = bucketValue >= Capital,
                Probability = ((double)counts[i] / simulationCount) * 100.0
            });
        }

        IsSimulated = true;
    }
}