@page "/guestbook"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@implements IDisposable

<PageTitle>실시간 익명 방명록</PageTitle>

<div class="container-fluid py-4" style="max-width: 900px;">
    
    <div class="mb-4 p-4 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #ff758c, #ff7eb3);">
        <h2 class="fw-bold text-white mb-2">
            <i class="bi bi-chat-heart-fill text-warning me-2"></i> 실시간 익명 방명록
        </h2>
        <p class="text-white opacity-90 mb-0 fs-5">방문자 여러분, 자유롭게 흔적을 남겨주세요! (새로고침 없이 실시간 갱신됩니다)</p>
    </div>

    <div class="row g-4">
        
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4" style="background-color: #f8f9fa;">
                <div class="card-body p-4">
                    <form @onsubmit="SubmitMessage">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-3">
                                <input type="text" class="form-control border-secondary p-3 fw-bold" 
                                       @bind="NewName" placeholder="닉네임 (익명)" maxlength="10" required />
                            </div>
                            <div class="col-md-7">
                                <input type="text" class="form-control border-secondary p-3" 
                                       @bind="NewContent" placeholder="여기에 따뜻한 메시지를 남겨주세요!" maxlength="100" required />
                            </div>
                            <div class="col-md-2 d-grid">
                                <button type="submit" class="btn btn-danger fw-bold p-3 rounded-3 shadow-sm">
                                    <i class="bi bi-send-fill me-1"></i> 남기기
                                </button>
                            </div>
                        </div>
                    </form>
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="text-danger fw-bold mt-2"><i class="bi bi-exclamation-triangle-fill me-1"></i>@ErrorMessage</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4" style="background-color: #fff;">
                <div class="card-header bg-transparent border-0 pt-4 pb-2 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-list-stars text-danger me-2"></i>최근 남겨진 메시지</h5>
                    <span class="badge bg-secondary rounded-pill">총 @MessageList.Count 개</span>
                </div>
                <div class="card-body p-4">
                    
                    @if (!MessageList.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-mailbox fs-1 opacity-25"></i>
                            <p class="mt-3 fw-bold fs-5">아직 첫 번째 발자국이 없습니다.<br/>가장 먼저 방명록을 남겨보세요!</p>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var msg in MessageList)
                            {
                                <div class="p-3 rounded-4 shadow-sm position-relative message-card" style="background-color: #fdfdfd; border-left: 5px solid @msg.ColorCode;">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div class="fw-bold fs-5" style="color: @msg.ColorCode;">
                                            <i class="bi bi-person-circle me-1"></i> @msg.Name
                                        </div>
                                        <div class="text-muted" style="font-size: 0.8rem;">
                                            @msg.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")
                                        </div>
                                    </div>
                                    <div class="text-dark fs-5" style="word-break: break-word;">
                                        @msg.Content
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .message-card { transition: transform 0.2s; }
    .message-card:hover { transform: translateX(5px); background-color: #f8f9fa !important; }
</style>

@code {
    // 💡 메시지 데이터 모델
    public class GuestMessage
    {
        public string Name { get; set; } = "";
        public string Content { get; set; } = "";
        public DateTime Timestamp { get; set; }
        public string ColorCode { get; set; } = "";
    }

    // 💡 [핵심 기술] static 키워드를 사용하여 모든 접속자가 이 리스트를 공유합니다! (DB 대체)
    private static List<GuestMessage> MessageList = new();
    
    // 💡 [핵심 기술] 누군가 글을 썼을 때 다른 사람의 화면을 갱신해주기 위한 이벤트
    private static event Action? OnMessageAdded;

    // 입력 폼 바인딩 변수
    private string NewName = "";
    private string NewContent = "";
    private string ErrorMessage = "";

    // 이름에 부여할 랜덤 색상 목록
    private readonly string[] Colors = { "#FF5733", "#33FF57", "#3357FF", "#F333FF", "#FFB533", "#33FFF5", "#E83354", "#8B33FF" };

    protected override void OnInitialized()
    {
        // 내 화면이 열릴 때 이벤트 구독 (누군가 글을 쓰면 UpdateUI 메서드 실행)
        OnMessageAdded += UpdateUI;
    }

    private void SubmitMessage()
    {
        if (string.IsNullOrWhiteSpace(NewName) || string.IsNullOrWhiteSpace(NewContent))
        {
            ErrorMessage = "닉네임과 내용을 모두 입력해주세요.";
            return;
        }

        ErrorMessage = "";
        
        var newMessage = new GuestMessage
        {
            Name = NewName,
            Content = NewContent,
            Timestamp = DateTime.Now,
            ColorCode = Colors[new Random().Next(Colors.Length)]
        };

        // 최신 글이 맨 위로 오도록 0번째 인덱스에 삽입
        MessageList.Insert(0, newMessage);

        // 메모리 절약을 위해 최근 100개까지만 유지
        if (MessageList.Count > 100)
        {
            MessageList.RemoveAt(MessageList.Count - 1);
        }

        // 폼 초기화
        NewName = "";
        NewContent = "";

        // 💡 글이 추가되었음을 모든 접속자에게 알림!
        OnMessageAdded?.Invoke();
    }

    // 다른 사람이 글을 썼을 때 내 화면을 새로고침해주는 메서드
    private async void UpdateUI()
    {
        await InvokeAsync(StateHasChanged);
    }

    // 화면을 닫을 때 이벤트 구독 해제 (메모리 누수 방지)
    public void Dispose()
    {
        OnMessageAdded -= UpdateUI;
    }
}