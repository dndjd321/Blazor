@page "/rpg-tracker"
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@using System.Text.Json

<PageTitle>RPG 퀘스트 트래커</PageTitle>

<div class="container-fluid py-4" style="max-width: 1200px;">
    
    <div class="card shadow-lg border-0 mb-4 rounded-4" style="background: linear-gradient(135deg, #1e222d, #2b3240);">
        <div class="card-body p-4 text-white">
            <div class="row align-items-center g-4">
                
                <div class="col-md-4 text-center text-md-start">
                    <div class="d-flex align-items-center justify-content-center justify-content-md-start mb-2">
                        <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-3 shadow" style="width: 70px; height: 70px;">
                            <i class="bi bi-person-bounding-box fs-1"></i>
                        </div>
                        <div>
                            <h3 class="fw-bold mb-0 text-warning">Lv.@Player.Level 개발자</h3>
                            <div class="text-light opacity-75 mt-1" style="font-size: 0.95rem;">
                                <i class="bi bi-fire text-danger"></i> 전투력(CP): <strong class="fs-5">@Player.CombatPower</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="d-flex justify-content-between mb-1" style="font-size: 0.9rem;">
                        <span class="fw-bold text-info">EXP</span>
                        <span class="text-light">@Player.Exp / @Player.MaxExp</span>
                    </div>
                    <div class="progress shadow-inner" style="height: 20px; background-color: #0f172a; border-radius: 10px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" 
                             role="progressbar" 
                             style="width: @((Player.Exp * 100) / Player.MaxExp)%"></div>
                    </div>
                    <div class="text-center mt-2" style="font-size: 0.8rem; color: #8fa0b5;">
                        할 일을 완료하여 경험치를 모으고 레벨업하세요!
                    </div>
                </div>

                <div class="col-md-3 text-center text-md-end">
                    <div class="p-3 rounded-4 shadow-sm" style="background-color: rgba(255, 215, 0, 0.1); border: 1px solid rgba(255, 215, 0, 0.3);">
                        <div class="text-warning fw-bold mb-1" style="font-size: 0.9rem;">보유 골드</div>
                        <h2 class="fw-bold mb-0" style="color: #ffd700; font-family: monospace;">
                            <i class="bi bi-coin me-2"></i>@Player.Gold.ToString("N0") <span class="fs-6 text-light">G</span>
                        </h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-xl-7">
            <div class="card shadow-sm border-0 h-100 rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <h5 class="fw-bold mb-0" style="color: #2c3e50;"><i class="bi bi-journal-bookmark-fill text-primary me-2"></i>일일 퀘스트 목록</h5>
                </div>
                <div class="card-body p-4">
                    
                    <div class="input-group shadow-sm mb-4">
                        <input type="text" class="form-control border-primary p-3 fw-bold" 
                               @bind="NewQuestTitle" @bind:event="oninput" @onkeyup="HandleKeyUp"
                               placeholder="새로운 퀘스트(할 일)를 입력하세요..." />
                        <button class="btn btn-primary fw-bold px-4" @onclick="AddQuest">
                            <i class="bi bi-plus-lg me-1"></i> 등록
                        </button>
                    </div>

                    <div class="list-group list-group-flush rounded-3 border">
                        @if (!Player.Quests.Any())
                        {
                            <div class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 opacity-25"></i>
                                <p class="mt-2 fw-bold">현재 진행 중인 퀘스트가 없습니다.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var quest in Player.Quests.OrderBy(q => q.IsCompleted))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center p-3 @(quest.IsCompleted ? "bg-light opacity-50" : "")">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="form-check">
                                            <input class="form-check-input fs-4 cursor-pointer" type="checkbox" 
                                                   checked="@quest.IsCompleted" 
                                                   @onchange='(e) => ToggleQuest(quest, (bool)(e.Value ?? false))'
                                                   disabled="@quest.IsCompleted">
                                        </div>
                                        <div>
                                            <h6 class="mb-1 fw-bold @(quest.IsCompleted ? "text-decoration-line-through text-muted" : "text-dark")">@quest.Title</h6>
                                            <div class="text-secondary" style="font-size: 0.85rem;">
                                                보상: <span class="text-info fw-bold"><i class="bi bi-arrow-up-circle"></i> @quest.RewardExp EXP</span> | 
                                                <span class="text-warning fw-bold"><i class="bi bi-coin"></i> @quest.RewardGold G</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteQuest(quest)">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            }
                        }
                    </div>
                    
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="card shadow-sm border-0 h-100 rounded-4" style="background-color: #f8f9fa;">
                <div class="card-header bg-transparent border-0 pt-4 pb-2">
                    <h5 class="fw-bold mb-0" style="color: #2c3e50;"><i class="bi bi-shop text-success me-2"></i>장비 상점 (전투력 강화)</h5>
                </div>
                <div class="card-body p-4">
                    
                    <div class="row g-3">
                        @foreach (var item in ShopItems)
                        {
                            bool isOwned = Player.Inventory.Contains(item.Id);
                            bool canAfford = Player.Gold >= item.Cost;

                            <div class="col-12">
                                <div class="card border-0 shadow-sm rounded-3 @(isOwned ? "border-success bg-success-subtle" : "")">
                                    <div class="card-body p-3 d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="fs-1">@item.Icon</div>
                                            <div>
                                                <h6 class="fw-bold mb-1 text-dark">@item.Name</h6>
                                                <div style="font-size: 0.85rem;">
                                                    <span class="text-danger fw-bold"><i class="bi bi-fire"></i> CP +@item.PowerBonus</span>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        @if (isOwned)
                                        {
                                            <span class="badge bg-success px-3 py-2 fs-6">보유중</span>
                                        }
                                        else
                                        {
                                            <button class="btn @(canAfford ? "btn-warning" : "btn-secondary") fw-bold px-3 py-2" 
                                                    disabled="@(!canAfford)" 
                                                    @onclick="() => BuyItem(item)">
                                                <i class="bi bi-coin"></i> @item.Cost.ToString("N0")
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    
                    @if (!string.IsNullOrEmpty(SystemMessage))
                    {
                        <div class="alert alert-success mt-4 fw-bold shadow-sm d-flex align-items-center text-break" style="animation: fadein 0.5s;">
                            <i class="bi bi-stars fs-4 me-2"></i> @SystemMessage
                        </div>
                    }

                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    @@keyframes fadein { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    // === 데이터 모델 ===
    public class RpgState
    {
        public int Level { get; set; } = 1;
        public int Exp { get; set; } = 0;
        public int MaxExp { get; set; } = 100;
        public int Gold { get; set; } = 0;
        public int CombatPower { get; set; } = 10;
        public List<Quest> Quests { get; set; } = new();
        public List<int> Inventory { get; set; } = new(); // 보유한 아이템 ID 리스트
    }

    public class Quest
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Title { get; set; } = "";
        public int RewardExp { get; set; }
        public int RewardGold { get; set; }
        public bool IsCompleted { get; set; } = false;
    }

    public class ShopItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Icon { get; set; } = "";
        public int Cost { get; set; }
        public int PowerBonus { get; set; }
    }

    // === 변수 및 상태 ===
    private RpgState Player = new RpgState();
    private string NewQuestTitle = "";
    private string SystemMessage = "";

    // 고정 상점 아이템 데이터
    private List<ShopItem> ShopItems = new()
    {
        new ShopItem { Id = 1, Name = "낡은 목검", Icon = "🗡️", Cost = 300, PowerBonus = 15 },
        new ShopItem { Id = 2, Name = "초보자 가죽 갑옷", Icon = "🦺", Cost = 800, PowerBonus = 40 },
        new ShopItem { Id = 3, Name = "기계식 키보드 (무기)", Icon = "⌨️", Cost = 2500, PowerBonus = 120 },
        new ShopItem { Id = 4, Name = "듀얼 모니터 방패", Icon = "🖥️", Cost = 5000, PowerBonus = 300 },
        new ShopItem { Id = 5, Name = "에스프레소 포션 (패시브)", Icon = "☕", Cost = 10000, PowerBonus = 800 }
    };

    // 💡 브라우저 LocalStorage에서 데이터 불러오기 (새로고침 방어)
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "RpgTrackerData");
                if (!string.IsNullOrEmpty(savedJson))
                {
                    Player = JsonSerializer.Deserialize<RpgState>(savedJson) ?? new RpgState();
                    StateHasChanged();
                }
            }
            catch { /* 로드 실패 시 무시하고 기본값 사용 */ }
        }
    }

    // 데이터 저장 메서드
    private async Task SaveData()
    {
        var json = JsonSerializer.Serialize(Player);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "RpgTrackerData", json);
    }

    // === 퀘스트 로직 ===
    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddQuest();
    }

    private async Task AddQuest()
    {
        if (string.IsNullOrWhiteSpace(NewQuestTitle)) return;

        // 글자 수에 비례해서 경험치와 골드를 랜덤하게 약간 더 줍니다. (최소 20 EXP, 50 Gold)
        int lengthBonus = NewQuestTitle.Length;
        
        Player.Quests.Add(new Quest
        {
            Title = NewQuestTitle,
            RewardExp = 20 + (lengthBonus * 2),
            RewardGold = 50 + (lengthBonus * 5)
        });

        NewQuestTitle = "";
        SystemMessage = "";
        await SaveData();
    }

    private async Task DeleteQuest(Quest q)
    {
        Player.Quests.Remove(q);
        await SaveData();
    }

    private async Task ToggleQuest(Quest q, bool isChecked)
    {
        if (isChecked && !q.IsCompleted)
        {
            q.IsCompleted = true;
            
            // 보상 획득
            Player.Exp += q.RewardExp;
            Player.Gold += q.RewardGold;

            SystemMessage = $"[{q.Title}] 완료! (+{q.RewardExp} EXP / +{q.RewardGold} G)";

            // 레벨업 체크
            if (Player.Exp >= Player.MaxExp)
            {
                Player.Exp -= Player.MaxExp;
                Player.Level++;
                Player.MaxExp = Player.Level * 100; // 레벨업 할수록 요구 경험치 증가
                Player.CombatPower += 5; // 레벨업 기본 스탯 상승
                
                SystemMessage = $"🎉 축하합니다! Lv.{Player.Level}(으)로 레벨업 하셨습니다! (기본 전투력 +5)";
            }

            await SaveData();
        }
    }

    // === 상점 로직 ===
    private async Task BuyItem(ShopItem item)
    {
        if (Player.Gold >= item.Cost && !Player.Inventory.Contains(item.Id))
        {
            Player.Gold -= item.Cost;
            Player.Inventory.Add(item.Id);
            Player.CombatPower += item.PowerBonus;
            
            SystemMessage = $"[{item.Name}] 구매 완료! 전투력이 {item.PowerBonus} 상승했습니다 🚀";
            await SaveData();
        }
    }
}