@page "/json"
@rendermode InteractiveServer
@using System.Text.Json
@inject IJSRuntime JSRuntime

<PageTitle>개발자 유틸 - JSON 포맷터</PageTitle>

<div class="container-fluid py-4" style="max-width: 1200px;">
    
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #2c3e50;">
            <i class="bi bi-filetype-json text-success me-2"></i>JSON 포맷터 & 변환기
        </h2>
        <p class="text-muted fs-5">복잡하고 지저분한 JSON 데이터를 보기 좋게 정렬하거나 용량을 줄이기 위해 압축합니다.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100 rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-0">
                    <h5 class="fw-bold text-primary mb-0"><i class="bi bi-box-arrow-in-down me-2"></i>입력 (Raw JSON)</h5>
                </div>
                <div class="card-body p-4 d-flex flex-column">
                    <textarea class="form-control font-monospace border bg-light flex-grow-1 mb-4 rounded-3 p-3 shadow-inner" 
                              @bind="InputJson" @bind:event="oninput" 
                              placeholder="여기에 정렬되지 않은 JSON 코드를 붙여넣으세요..." 
                              style="font-size: 0.95rem; min-height: 400px; resize: none;"></textarea>
                    
                    <div class="d-flex gap-2">
                        <button class="btn btn-success fw-bold flex-grow-1 shadow-sm py-2" @onclick="FormatJson">
                            <i class="bi bi-stars me-1"></i> 예쁘게 정렬
                        </button>
                        <button class="btn btn-warning fw-bold flex-grow-1 shadow-sm py-2" @onclick="MinifyJson" style="color: #856404;">
                            <i class="bi bi-arrows-collapse me-1"></i> 한 줄 압축
                        </button>
                        <button class="btn btn-outline-danger fw-bold shadow-sm py-2 px-4" @onclick="ClearAll">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100 rounded-4" style="background-color: #282c34;">
                <div class="card-header border-0 pt-4 pb-0 bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-success mb-0"><i class="bi bi-box-arrow-up text-success me-2"></i>결과 (Result)</h5>
                    
                    <button class="btn btn-sm fw-bold @CopyButtonClass px-3" @onclick="CopyToClipboard" disabled="@string.IsNullOrEmpty(OutputJson)">
                        <i class="bi bi-clipboard me-1"></i> @CopyButtonText
                    </button>
                </div>
                <div class="card-body p-4 d-flex flex-column">
                    <textarea class="form-control font-monospace flex-grow-1 border-0 rounded-3 p-3" readonly
                              style="font-size: 0.95rem; background-color: #1e222d; color: #abb2bf; min-height: 400px; resize: none;"
                              value="@OutputJson"></textarea>
                    
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger mt-3 mb-0 shadow-sm d-flex align-items-center" role="alert">
                            <i class="bi bi-x-circle-fill fs-5 me-2"></i>
                            <div><strong>변환 실패!</strong> 올바른 JSON 형식이 아닙니다.</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string InputJson = "";
    private string OutputJson = "";
    private string ErrorMessage = "";

    private string CopyButtonText = "복사하기";
    private string CopyButtonClass = "btn-outline-success";

    private void FormatJson()
    {
        if (string.IsNullOrWhiteSpace(InputJson)) return;
        try
        {
            ErrorMessage = ""; 
            var jsonElement = JsonSerializer.Deserialize<JsonElement>(InputJson);
            var options = new JsonSerializerOptions { WriteIndented = true };
            OutputJson = JsonSerializer.Serialize(jsonElement, options);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            OutputJson = "";
        }
    }

    private void MinifyJson()
    {
        if (string.IsNullOrWhiteSpace(InputJson)) return;
        try
        {
            ErrorMessage = "";
            var jsonElement = JsonSerializer.Deserialize<JsonElement>(InputJson);
            var options = new JsonSerializerOptions { WriteIndented = false };
            OutputJson = JsonSerializer.Serialize(jsonElement, options);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            OutputJson = "";
        }
    }

    private void ClearAll()
    {
        InputJson = "";
        OutputJson = "";
        ErrorMessage = "";
        CopyButtonText = "복사하기";
        CopyButtonClass = "btn-outline-success";
    }

    private async Task CopyToClipboard()
    {
        if (string.IsNullOrEmpty(OutputJson)) return;
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", OutputJson);
            CopyButtonText = "복사 완료!";
            CopyButtonClass = "btn-success";
            await Task.Delay(2000);
            CopyButtonText = "복사하기";
            CopyButtonClass = "btn-outline-success";
        }
        catch
        {
            CopyButtonText = "실패";
            CopyButtonClass = "btn-danger";
            await Task.Delay(2000);
            CopyButtonText = "복사하기";
            CopyButtonClass = "btn-outline-success";
        }
    }
}