@page "/yugioh-deck-maker"
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>유희왕 덱 메이커</PageTitle>

<div class="container-fluid py-4" style="max-width: 1400px;">
    
    <div class="mb-4 p-4 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #2b1055, #7597de); border: 2px solid #e2b714;">
        <h2 class="fw-bold text-white mb-2" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">
            <i class="bi bi-suit-spade-fill text-warning me-2"></i> 유희왕 덱 메이커 (Yu-Gi-Oh!)
        </h2>
        <p class="text-light opacity-90 mb-0 fs-5">전 세계 모든 카드를 검색하고 나만의 최강 덱을 완성하세요.</p>
    </div>

    <div class="row g-4">
        
        <div class="col-xl-5 col-lg-6">
            <div class="card shadow-lg border-0 h-100 rounded-4" style="background-color: #f8f9fa;">
                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <h5 class="fw-bold mb-0" style="color: #2c3e50;"><i class="bi bi-search text-primary me-2"></i>카드 검색 (영문)</h5>
                </div>
                <div class="card-body p-4 d-flex flex-column gap-3">
                    
                    <div class="input-group shadow-sm">
                        <input type="text" class="form-control border-primary p-3 fw-bold" 
                               @bind="SearchQuery" @bind:event="oninput" @onkeyup="HandleKeyUp"
                               placeholder="예: Blue-Eyes, Dark Magician..." />
                        <button class="btn btn-primary fw-bold px-4" @onclick="SearchCards" disabled="@IsSearching">
                            @if(IsSearching) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            검색
                        </button>
                    </div>
                    <div class="text-muted" style="font-size: 0.85rem;"><i class="bi bi-info-circle"></i> 글로벌 API 규격에 따라 영문 이름으로 검색해주세요.</div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-warning fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>@ErrorMessage</div>
                    }

                    <div class="row g-2 overflow-auto p-2 border rounded-3 bg-light flex-grow-1" style="max-height: 600px;">
                        @if (SearchResults != null && SearchResults.Any())
                        {
                            @foreach (var card in SearchResults)
                            {
                                <div class="col-4 col-md-3">
                                    <YgoCardDisplay Card="card" OnCardClicked="AddToDeck" />
                                </div>
                            }
                        }
                        else if (!IsSearching && SearchResults != null && !SearchResults.Any())
                        {
                            <div class="col-12 text-center text-muted py-5">
                                검색 결과가 없습니다.
                            </div>
                        }
                    </div>
                    <script src="yugioh.js"></script>

                </div>
            </div>
        </div>

        <div class="col-xl-7 col-lg-6">
            <div class="card shadow-lg border-0 h-100 rounded-4" style="background-color: #1e222d; border: 1px solid #e2b714 !important;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-warning"><i class="bi bi-inboxes-fill me-2"></i>나만의 덱 (My Deck)</h5>
                    <div>
                        <button class="btn btn-sm btn-outline-danger me-2 fw-bold" @onclick="ClearDeck"><i class="bi bi-trash3"></i> 비우기</button>
                        <button class="btn btn-sm btn-warning fw-bold text-dark" @onclick="SaveDeck"><i class="bi bi-save"></i> 덱 저장</button>
                    </div>
                </div>
                <div class="card-body p-4 d-flex flex-column gap-4">
                    
                    @if (!string.IsNullOrEmpty(SystemMessage))
                    {
                        <div class="alert alert-success fw-bold py-2 mb-0 shadow-sm" style="animation: fadein 0.5s;">@SystemMessage</div>
                    }

                    <div>
                        <div class="d-flex justify-content-between text-light mb-2">
                            <span class="fw-bold">메인 덱 (Main Deck)</span>
                            <span class="badge @(MainDeck.Count >= 40 && MainDeck.Count <= 60 ? "bg-success" : "bg-secondary")">@MainDeck.Count / 60 장</span>
                        </div>
                        <div class="p-3 rounded-3 shadow-inner d-flex flex-wrap gap-2 align-content-start overflow-auto" style="background-color: #2b3240; min-height: 250px; max-height: 350px;">
                            @foreach (var card in MainDeck)
                            {
                                <div class="position-relative cursor-pointer deck-card-hover" style="width: 60px;" @onclick="() => RemoveFromDeck(card, false)">
                                    <img src="@card.CardImages.FirstOrDefault()?.ImageUrlSmall" class="img-fluid rounded shadow-sm" alt="@card.Name">
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem; z-index: 10; display: none;">X</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div>
                        <div class="d-flex justify-content-between text-light mb-2">
                            <span class="fw-bold text-info">엑스트라 덱 (Extra Deck)</span>
                            <span class="badge @(ExtraDeck.Count == 15 ? "bg-info text-dark" : "bg-secondary")">@ExtraDeck.Count / 15 장</span>
                        </div>
                        <div class="p-3 rounded-3 shadow-inner d-flex flex-wrap gap-2 align-content-start overflow-auto" style="background-color: #2b3240; min-height: 120px;">
                            @foreach (var card in ExtraDeck)
                            {
                                <div class="position-relative cursor-pointer deck-card-hover" style="width: 60px;" @onclick="() => RemoveFromDeck(card, true)">
                                    <img src="@card.CardImages.FirstOrDefault()?.ImageUrlSmall" class="img-fluid rounded shadow-sm" alt="@card.Name">
                                </div>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .card-hover { transition: transform 0.2s; }
    .card-hover:hover { transform: scale(1.05); z-index: 10; border: 2px solid #0d6efd !important; }
    .deck-card-hover { transition: transform 0.1s; }
    .deck-card-hover:hover { transform: translateY(-5px); opacity: 0.8; }
    .deck-card-hover:hover span { display: block !important; }
    @@keyframes fadein { from { opacity: 0; } to { opacity: 1; } }
</style>

@code {
    // === 상태 변수 ===
    private string SearchQuery = "";
    private bool IsSearching = false;
    private string ErrorMessage = "";
    private string SystemMessage = "";
    
    private List<YgoCard> SearchResults = new();
    private List<YgoCard> MainDeck = new();
    private List<YgoCard> ExtraDeck = new();

    // 💡 브라우저 LocalStorage에서 내 덱 불러오기
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var mainJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "MainDeck");
                var extraJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "ExtraDeck");
                
                if (!string.IsNullOrEmpty(mainJson)) MainDeck = JsonSerializer.Deserialize<List<YgoCard>>(mainJson) ?? new();
                if (!string.IsNullOrEmpty(extraJson)) ExtraDeck = JsonSerializer.Deserialize<List<YgoCard>>(extraJson) ?? new();
                
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task SaveDeck()
    {
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "MainDeck", JsonSerializer.Serialize(MainDeck));
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "ExtraDeck", JsonSerializer.Serialize(ExtraDeck));
        SystemMessage = "덱이 브라우저에 성공적으로 저장되었습니다!";
        await Task.Delay(3000); // 3초 뒤 메시지 지우기
        SystemMessage = "";
    }

    private void ClearDeck()
    {
        MainDeck.Clear();
        ExtraDeck.Clear();
        SystemMessage = "덱을 초기화했습니다.";
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = SearchCards();
    }

    // 💡 글로벌 무료 API 호출
    private async Task SearchCards()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery)) return;

        IsSearching = true;
        ErrorMessage = "";
        SearchResults.Clear();
        SystemMessage = "";

        try
        {
            using var client = new HttpClient();
            // fname 파라미터로 퍼지(유사) 검색 지원
            string url = $"https://db.ygoprodeck.com/api/v7/cardinfo.php?fname={Uri.EscapeDataString(SearchQuery)}";
            
            var response = await client.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                var apiResult = await response.Content.ReadFromJsonAsync<YgoApiResponse>();
                if (apiResult != null && apiResult.Data != null)
                {
                    // 너무 많은 결과 방지 (최대 50장)
                    SearchResults = apiResult.Data.Take(50).ToList();
                }
            }
            else
            {
                ErrorMessage = "검색 결과가 없습니다. 스펠링을 확인해주세요.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "API 통신 오류: " + ex.Message;
        }
        finally
        {
            IsSearching = false;
        }
    }

    // 💡 덱 조립 로직 (유희왕 공식 룰 기반)
    private void AddToDeck(YgoCard card)
    {
        SystemMessage = "";
        ErrorMessage = "";

        // 엑스트라 덱 몬스터 판별
        bool isExtra = card.Type.Contains("Fusion") || card.Type.Contains("Synchro") || card.Type.Contains("XYZ") || card.Type.Contains("Link");
        
        var targetDeck = isExtra ? ExtraDeck : MainDeck;
        int maxCount = isExtra ? 15 : 60;

        // 룰 체크 1: 덱 최대 장수 제한
        if (targetDeck.Count >= maxCount)
        {
            ErrorMessage = isExtra ? "엑스트라 덱은 최대 15장까지입니다." : "메인 덱은 최대 60장까지입니다.";
            return;
        }

        // 룰 체크 2: 동일 카드 최대 3장 제한 (메인+엑스트라 합산)
        int currentCopies = MainDeck.Count(c => c.Id == card.Id) + ExtraDeck.Count(c => c.Id == card.Id);
        if (currentCopies >= 3)
        {
            ErrorMessage = "동일한 카드는 덱에 최대 3장까지만 넣을 수 있습니다.";
            return;
        }

        targetDeck.Add(card);
        // 정렬: 몬스터, 마법, 함정 순으로 대략적인 정렬
        if (!isExtra) MainDeck = MainDeck.OrderBy(c => c.Type).ToList();
    }

    private void RemoveFromDeck(YgoCard card, bool isExtra)
    {
        if (isExtra) ExtraDeck.Remove(card);
        else MainDeck.Remove(card);
    }
}