@page "/whale-tracker"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Text.Json
@using System.Numerics
@using System.Globalization

<PageTitle>이더리움 고래 지갑 추적기</PageTitle>

<div class="container-fluid py-4" style="max-width: 1200px;">
    
    <div class="mb-4 p-4 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #1e222d, #0f172a);">
        <h2 class="fw-bold text-white mb-2">
            <i class="bi bi-eye-fill text-info me-2"></i> 고래 지갑 추적기 (ETH)
        </h2>
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-2">
            <p class="text-light opacity-75 mb-0 fs-5">전 세계 최고 부자들의 이더리움 지갑 잔고를 실시간으로 훔쳐보세요.</p>
            <span class="badge bg-success fs-6 py-2 px-3 shadow-sm">
                <i class="bi bi-currency-exchange me-1"></i> 현재 적용 환율: 1달러 = ₩@CurrentExchangeRate.ToString("N2")
            </span>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-5">
            <div class="card shadow-lg border-0 h-100 rounded-4" style="background-color: #f8f9fa;">
                <div class="card-body p-4 d-flex flex-column gap-4">
                    
                    <div>
                        <label class="form-label fw-bold text-secondary">추적할 이더리움 지갑 주소 (0x...)</label>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-primary text-white border-0"><i class="bi bi-wallet2"></i></span>
                            <input type="text" class="form-control border-0 font-monospace text-dark fw-bold" 
                                   @bind="WalletAddress" @bind:event="oninput" 
                                   placeholder="0x로 시작하는 지갑 주소 입력" />
                            <button class="btn btn-primary fw-bold px-4" @onclick="TrackWallet" disabled="@IsLoading">
                                @if(IsLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                조회
                            </button>
                        </div>
                    </div>

                    <div class="alert alert-light border shadow-sm mb-0">
                        <h6 class="fw-bold text-dark mb-3"><i class="bi bi-star-fill text-warning me-2"></i>유명 고래 지갑 (클릭하여 조회)</h6>
                        <div class="d-flex flex-column gap-2">
                            <button class="btn btn-outline-dark text-start fw-bold" @onclick='() => SetPresetAndTrack("0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045", "비탈릭 부테린 (이더리움 창시자)")'>
                                🦄 비탈릭 부테린 (Vitalik Buterin)
                            </button>
                            <button class="btn btn-outline-dark text-start fw-bold" @onclick='() => SetPresetAndTrack("0xbe0eB53F46cd790Cd13851d5EFf43D12404d33E8", "바이낸스 거래소 콜드월렛")'>
                                🏦 바이낸스 콜드월렛 (Binance 7)
                            </button>
                            <button class="btn btn-outline-dark text-start fw-bold" @onclick='() => SetPresetAndTrack("0x00000000219ab540356cBB839Cbe05303d7705Fa", "이더리움 스테이킹 컨트랙트")'>
                                🔒 이더리움 2.0 스테이킹 지갑
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger fw-bold mt-auto mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>@ErrorMessage</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-7">
            <div class="card shadow-lg border-0 h-100 rounded-4" style="background-color: #1e222d; border: 1px solid #2b3240 !important;">
                <div class="card-header bg-transparent border-0 pt-4 pb-0">
                    <h5 class="fw-bold mb-0 text-info"><i class="bi bi-pie-chart-fill me-2"></i>실시간 자산 분석</h5>
                    @if (!string.IsNullOrEmpty(TargetName))
                    {
                        <div class="badge bg-secondary mt-2 fs-6">@TargetName</div>
                    }
                </div>
                <div class="card-body p-4 d-flex flex-column justify-content-center">
                    
                    @if (HasData)
                    {
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="p-4 rounded-4 shadow-sm h-100" style="background-color: #2b3240;">
                                    <div class="text-secondary fw-bold mb-2">보유 이더리움 (ETH)</div>
                                    <h2 class="text-white fw-bold font-monospace mb-0 text-break">
                                        <i class="bi bi-currency-bitcoin text-secondary fs-4 me-1"></i>@EthBalance.ToString("N4")
                                    </h2>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="p-4 rounded-4 shadow-sm h-100" style="background-color: #2b3240;">
                                    <div class="text-secondary fw-bold mb-2">현재 ETH 시세 (바이낸스)</div>
                                    <h3 class="text-info fw-bold font-monospace mb-0">
                                        $@CurrentEthPrice.ToString("N2")
                                    </h3>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="p-4 rounded-4 shadow-inner text-center" style="background: linear-gradient(135deg, rgba(13,202,240,0.1), rgba(25,135,84,0.1)); border: 1px solid rgba(13,202,240,0.2);">
                                    <div class="text-secondary fw-bold mb-2">총 원화 환산 가치 (적용 환율 ₩@CurrentExchangeRate.ToString("N2"))</div>
                                    <h1 class="text-success fw-bold font-monospace mb-2" style="font-size: 3rem;">
                                        ₩@TotalKrwValue.ToString("N0")
                                    </h1>
                                    <div class="text-light fs-5 font-monospace">
                                        ( 약 $@TotalUsdValue.ToString("N0") )
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 text-center">
                            <a href="https://etherscan.io/address/@WalletAddress" target="_blank" class="btn btn-outline-info fw-bold rounded-pill px-4">
                                <i class="bi bi-search me-1"></i> 이더스캔에서 상세 거래내역 보기
                            </a>
                        </div>
                    }
                    else if (!IsLoading)
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-search" style="font-size: 4rem; opacity: 0.2;"></i>
                            <h5 class="mt-3 fw-bold">지갑 주소를 입력하고 조회해보세요.</h5>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private string WalletAddress = "";
    private string TargetName = "";
    private bool IsLoading = false;
    private bool HasData = false;
    private string ErrorMessage = "";

    private double EthBalance = 0;
    private double CurrentEthPrice = 0;
    private double CurrentExchangeRate = 1350; // 초기값 (실패 시 대비)
    private double TotalUsdValue = 0;
    private double TotalKrwValue = 0;

    // 💡 페이지가 처음 켜질 때 백그라운드에서 실시간 환율을 딱 한 번 가져옵니다.
    protected override async Task OnInitializedAsync()
    {
        await LoadRealtimeExchangeRate();
    }

    private async Task LoadRealtimeExchangeRate()
    {
        try
        {
            using var client = new HttpClient();
            // 안정적인 무료 환율 API로 변경
            var exchangeResponse = await client.GetFromJsonAsync<JsonElement>("https://api.exchangerate-api.com/v4/latest/USD");
            
            if (exchangeResponse.TryGetProperty("rates", out var ratesElement) && 
                ratesElement.TryGetProperty("KRW", out var krwElement))
            {
                CurrentExchangeRate = krwElement.GetDouble();
            }
        }
        catch (Exception)
        {
            // 네트워크 오류 시 1350원으로 유지
            Console.WriteLine("환율 정보를 불러오는 데 실패했습니다.");
        }
    }

    private async Task SetPresetAndTrack(string address, string name)
    {
        WalletAddress = address;
        TargetName = name;
        await TrackWallet();
    }

    private async Task TrackWallet()
    {
        if (string.IsNullOrWhiteSpace(WalletAddress) || !WalletAddress.StartsWith("0x"))
        {
            ErrorMessage = "올바른 이더리움 지갑 주소(0x...)를 입력해주세요.";
            return;
        }

        IsLoading = true;
        ErrorMessage = "";
        HasData = false;
        
        if (TargetName != "" && WalletAddress != "0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045" && WalletAddress != "0xbe0eB53F46cd790Cd13851d5EFf43D12404d33E8" && WalletAddress != "0x00000000219ab540356cBB839Cbe05303d7705Fa")
        {
            TargetName = "직접 입력한 지갑";
        }

        try
        {
            using var client = new HttpClient();

            // 1. 바이낸스 가격
            var priceResponse = await client.GetFromJsonAsync<JsonElement>("https://api.binance.com/api/v3/ticker/price?symbol=ETHUSDT");
            if (priceResponse.TryGetProperty("price", out var priceElement))
            {
                CurrentEthPrice = double.Parse(priceElement.GetString()!);
            }
            else
            {
                ErrorMessage = "바이낸스 시세를 불러올 수 없습니다.";
                IsLoading = false;
                return;
            }

            // 2. LlamaRPC 무료 퍼블릭 노드
            string jsonPayload = $"{{\"jsonrpc\":\"2.0\",\"method\":\"eth_getBalance\",\"params\":[\"{WalletAddress}\", \"latest\"],\"id\":1}}";
            var content = new StringContent(jsonPayload, System.Text.Encoding.UTF8, "application/json");
            
            var ethResponse = await client.PostAsync("https://eth.llamarpc.com", content);
            ethResponse.EnsureSuccessStatusCode();
            var ethResult = await ethResponse.Content.ReadFromJsonAsync<JsonElement>();

            if (ethResult.TryGetProperty("error", out var errorElement))
            {
                ErrorMessage = "이더리움 노드 응답 오류: " + errorElement.GetProperty("message").GetString();
                IsLoading = false;
                return;
            }

            if (ethResult.TryGetProperty("result", out var resultElement))
            {
                string hexBalance = resultElement.GetString()!;
                if (string.IsNullOrEmpty(hexBalance) || hexBalance == "0x0" || hexBalance == "0")
                {
                    EthBalance = 0;
                }
                else
                {
                    hexBalance = hexBalance.Replace("0x", "");
                    BigInteger weiBalance = BigInteger.Parse("0" + hexBalance, NumberStyles.HexNumber);
                    EthBalance = (double)weiBalance / Math.Pow(10, 18);
                }

                TotalUsdValue = EthBalance * CurrentEthPrice;
                // 💡 미리 불러온 실시간 환율을 적용하여 계산합니다!
                TotalKrwValue = TotalUsdValue * CurrentExchangeRate;

                HasData = true;
            }
            else
            {
                ErrorMessage = "잔고 정보를 읽을 수 없습니다.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "정보를 불러오는 중 오류가 발생했습니다: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}